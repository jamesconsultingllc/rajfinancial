{
  "name": "@rajfinancial/e2e-tests",
  "version": "1.0.0",
  "private": true,
  "description": "E2E acceptance tests using Cucumber.js + Playwright (TypeScript)",
  "scripts": {
    "test": "cucumber-js",
    "test:chromium": "cross-env BROWSER=chromium cucumber-js",
    "test:firefox": "cross-env BROWSER=firefox cucumber-js",
    "test:webkit": "cross-env BROWSER=webkit cucumber-js",
    "test:headed": "cross-env HEADED=true cucumber-js",
    "playwright:install": "playwright install --with-deps",
    "report": "echo 'Reports generated in reports/'"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.2.0",
    "@playwright/test": "^1.52.0",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^22.15.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "imapflow": "^1.2.10",
    "mailparser": "^3.9.3"
  }
}
