# E2E Test Configuration
# Copy to .env and fill in values

# Base URL of the deployed application
BASE_URL=https://localhost:8080

# Browser to use: chromium | firefox | webkit
BROWSER=chromium

# Set to "true" to run in headed mode (visible browser)
HEADED=

# Test user passwords (from Azure Key Vault or CI secrets)
TEST_CLIENT_PASSWORD=
TEST_ADMINISTRATOR_PASSWORD=

# IMAP settings for email verification (signup flow)
IMAP_HOST=
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=
