{
  "name": "rajfinancial",
  "version": "1.0.0",
  "description": "RAJ Financial Application",
  "scripts": {
    "start": "swa start",
    "test:e2e": "dotnet test tests/AcceptanceTests/RajFinancial.AcceptanceTests.csproj --verbosity normal",
    "test:e2e:ci": "concurrently -k -s first \"npm run start\" \"npm run test:e2e:wait\"",
    "test:e2e:wait": "wait-on http://localhost:4280 -t 60000 && npm run test:e2e",
    "test:all": "dotnet test src/RajFinancial.sln --verbosity normal",
    "build": "dotnet build src/RajFinancial.sln -c Release"
  },
  "devDependencies": {
    "@azure/static-web-apps-cli": "^2.0.1",
    "@vitejs/plugin-basic-ssl": "^1.2.0",
    "concurrently": "^9.1.0",
    "wait-on": "^8.0.1"
  }
}
