	<s:Boolean x:Key="/Default/UserDictionary/Words/=Reqnroll/@EntryIndexedValue">True</s:Boolean>
	<s:Boolean x:Key="/Default/UserDictionary/Words/=testid/@EntryIndexedValue">True</s:Boolean></wpf:ResourceDictionary>