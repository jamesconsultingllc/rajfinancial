# Production env vars are injected by CI via .env.local (see GitHub workflow).
# Do NOT place real values here — Vite loads this file automatically in
# production mode, so placeholders would get baked into the bundle.
#
# Required variables (set via GitHub environment secrets/variables):
#   VITE_AZURE_AD_AUTHORITY=https://<tenant>.ciamlogin.com/<tenant>.onmicrosoft.com
#   VITE_AZURE_AD_CLIENT_ID=<spa-app-client-id>
#   VITE_MSAL_CACHE_LOCATION=sessionStorage
