@*
    NavMenu.razor
    
    Main navigation menu demonstrating policy-based authorization.
    Menu items are hidden (not disabled) based on user's role using AuthorizeView.
    
    Features:
    - Brand logo with link to home
    - Role-based menu sections
    - Gold accent for active states
    - WCAG 2.1 AA accessible
    - Fully localized
    
    Authorization Policies Used:
    - RequireClient: Visible to Clients, Advisors, and Administrators
    - RequireAdvisor: Visible to Advisors and Administrators
    - RequireAdministrator: Visible to Administrators only
*@

@using Microsoft.Extensions.Localization
@inject IStringLocalizer<NavMenu> L

@* Brand Header *@
<div class="nav-brand">
    <a href="" class="nav-brand-link" aria-label="@L["Brand.Home.AriaLabel"]">
        <img src="/images/brand/logo-horizontal.svg" alt="" class="nav-brand-icon" width="40" height="40" role="presentation" />
        <span class="nav-brand-text">@L["Brand.Name"]</span>
    </a>
</div>

@* Navigation Links *@
<nav class="nav-menu" aria-label="@L["Nav.AriaLabel"]" @onclick="HandleNavClick">
    @* Public Links - Always visible *@
    <div class="nav-section">
        <NavLink class="nav-link" href="" Match="NavLinkMatch.All" data-testid="nav-home-link">
            <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                <polyline points="9 22 9 12 15 12 15 22"></polyline>
            </svg>
            <span>@L["Nav.Home"]</span>
        </NavLink>
    </div>

    @* Client Features - Visible to authenticated users with Client, Advisor, or Administrator role *@
    <AuthorizeView Policy="RequireClient">
        <Authorized>
            <div class="nav-section">
                <div class="nav-section-title" data-testid="my-account">@L["Section.MyAccount"]</div>
                <NavLink class="nav-link" href="portfolio" data-testid="nav-portfolio-link">
                    <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                        <path d="M21.21 15.89A10 10 0 1 1 8 2.83"></path>
                        <path d="M22 12A10 10 0 0 0 12 2v10z"></path>
                    </svg>
                    <span>@L["Nav.Portfolio"]</span>
                </NavLink>
                <NavLink class="nav-link" href="transactions" data-testid="nav-transactions-link">
                    <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                        <line x1="8" y1="6" x2="21" y2="6"></line>
                        <line x1="8" y1="12" x2="21" y2="12"></line>
                        <line x1="8" y1="18" x2="21" y2="18"></line>
                        <line x1="3" y1="6" x2="3.01" y2="6"></line>
                        <line x1="3" y1="12" x2="3.01" y2="12"></line>
                        <line x1="3" y1="18" x2="3.01" y2="18"></line>
                    </svg>
                    <span>@L["Nav.Transactions"]</span>
                </NavLink>
                <NavLink class="nav-link" href="statements" data-testid="nav-statements-link">
                    <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                        <polyline points="14 2 14 8 20 8"></polyline>
                        <line x1="16" y1="13" x2="8" y2="13"></line>
                        <line x1="16" y1="17" x2="8" y2="17"></line>
                        <polyline points="10 9 9 9 8 9"></polyline>
                    </svg>
                    <span>@L["Nav.Statements"]</span>
                </NavLink>
            </div>
        </Authorized>
    </AuthorizeView>

    @* Advisor Features - Visible to Advisors and Administrators *@
    <AuthorizeView Policy="RequireAdvisor">
        <Authorized>
            <div class="nav-section">
                <div class="nav-section-title">@L["Section.AdvisorTools"]</div>
                <NavLink class="nav-link" href="advisor/clients" data-testid="nav-my-clients-link">
                    <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                        <circle cx="9" cy="7" r="4"></circle>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                    </svg>
                    <span>@L["Nav.MyClients"]</span>
                </NavLink>
                <NavLink class="nav-link" href="advisor/reports" data-testid="nav-reports-link">
                    <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                        <line x1="18" y1="20" x2="18" y2="10"></line>
                        <line x1="12" y1="20" x2="12" y2="4"></line>
                        <line x1="6" y1="20" x2="6" y2="14"></line>
                    </svg>
                    <span>@L["Nav.Reports"]</span>
                </NavLink>
            </div>
        </Authorized>
    </AuthorizeView>

    @* Administrator Features - Visible to Administrators only *@
    <AuthorizeView Policy="RequireAdministrator">
        <Authorized>
            <div class="nav-section">
                <div class="nav-section-title">@L["Section.Administration"]</div>
                <NavLink class="nav-link" href="admin/dashboard" data-testid="admin-dashboard-link">
                    <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                        <rect x="3" y="3" width="7" height="7"></rect>
                        <rect x="14" y="3" width="7" height="7"></rect>
                        <rect x="14" y="14" width="7" height="7"></rect>
                        <rect x="3" y="14" width="7" height="7"></rect>
                    </svg>
                    <span>@L["Nav.Dashboard"]</span>
                </NavLink>
                <NavLink class="nav-link" href="admin/users" data-testid="admin-users-link">
                    <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                        <circle cx="12" cy="7" r="4"></circle>
                    </svg>
                    <span>@L["Nav.UserManagement"]</span>
                </NavLink>
                <NavLink class="nav-link" href="admin/settings" data-testid="admin-settings-link">
                    <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                        <circle cx="12" cy="12" r="3"></circle>
                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
                    </svg>
                    <span>@L["Nav.Settings"]</span>
                </NavLink>
            </div>
        </Authorized>
    </AuthorizeView>
</nav>

@code {
    /// <summary>
    /// Event callback to notify parent when navigation occurs (for closing mobile sidebar).
    /// </summary>
    [Parameter]
    public EventCallback OnNavigate { get; set; }

    /// <summary>
    /// Handles click events on the navigation to close mobile sidebar.
    /// </summary>
    private async Task HandleNavClick()
    {
        if (OnNavigate.HasDelegate)
        {
            await OnNavigate.InvokeAsync();
        }
    }
}
