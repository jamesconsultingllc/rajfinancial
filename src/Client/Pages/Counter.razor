@*
    Counter.razor
    
    Demo counter page showing interactive Blazor functionality.
    
    Features:
    - WCAG 2.1 AA accessible
    - Fully localized
*@

@page "/counter"

@using Microsoft.Extensions.Localization
@inject IStringLocalizer<Counter> L

<PageTitle>@L["PageTitle"]</PageTitle>

<h1>@L["Heading"]</h1>

<p role="status" aria-live="polite">@string.Format(L["CurrentCount"], currentCount)</p>

<button class="btn btn-primary" 
        @onclick="IncrementCount"
        aria-label="@L["IncrementCount.AriaLabel"]">
    @L["ClickMe"]
</button>

@code {
    private int currentCount = 0;

    private void IncrementCount()
    {
        currentCount++;
    }
}
