@*
    Dashboard.razor (Client Dashboard)
    
    Main dashboard for authenticated Client users.
    Displays welcome message and quick action cards.
    
    Features:
    - Welcome message with user name
    - Quick action cards for portfolio, transactions, statements
    - Responsive design (mobile-first)
    - WCAG 2.1 AA accessible
    - Fully localized
*@

@page "/dashboard"
@attribute [Authorize]
@inject IStringLocalizer<Dashboard> L

<PageTitle>@L["PageTitle"]</PageTitle>

<div class="dashboard-container">
    @* Welcome Section *@
    <section class="welcome-section animate-fade-in" aria-labelledby="welcome-heading">
        <div class="welcome-content">
            <h1 id="welcome-heading" class="welcome-title" data-testid="dashboard-title">
                @L["Welcome.Title.Prefix"]<span class="text-gold">,</span>
                <AuthorizeView>
                    <Authorized>
                        <span class="welcome-name">@context.User.Identity?.Name</span>
                    </Authorized>
                </AuthorizeView>
            </h1>
            <p class="welcome-subtitle">
                @L["Welcome.Subtitle"]
            </p>
        </div>
    </section>

    @* Quick Action Cards *@
    <section class="quick-actions-grid" aria-label="@L["QuickActions.AriaLabel"]">
        <a href="portfolio" class="action-card card-premium animate-slide-up stagger-1" data-testid="portfolio-action">
            <div class="action-icon bg-gold-50" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gold-dark" aria-hidden="true" focusable="false">
                    <path d="M21.21 15.89A10 10 0 1 1 8 2.83"></path>
                    <path d="M22 12A10 10 0 0 0 12 2v10z"></path>
                </svg>
            </div>
            <div class="action-content">
                <h2 class="action-title">@L["Action.Portfolio.Title"]</h2>
                <p class="action-description">@L["Action.Portfolio.Description"]</p>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="action-arrow" aria-hidden="true" focusable="false">
                <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
        </a>

        <a href="transactions" class="action-card card-premium animate-slide-up stagger-2" data-testid="transactions-action">
            <div class="action-icon bg-gold-50" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gold-dark" aria-hidden="true" focusable="false">
                    <line x1="12" y1="1" x2="12" y2="23"></line>
                    <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                </svg>
            </div>
            <div class="action-content">
                <h2 class="action-title">@L["Action.Transactions.Title"]</h2>
                <p class="action-description">@L["Action.Transactions.Description"]</p>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="action-arrow" aria-hidden="true" focusable="false">
                <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
        </a>

        <a href="statements" class="action-card card-premium animate-slide-up stagger-3" data-testid="statements-action">
            <div class="action-icon bg-gold-50" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gold-dark" aria-hidden="true" focusable="false">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                    <polyline points="14 2 14 8 20 8"></polyline>
                    <line x1="16" y1="13" x2="8" y2="13"></line>
                    <line x1="16" y1="17" x2="8" y2="17"></line>
                </svg>
            </div>
            <div class="action-content">
                <h2 class="action-title">@L["Action.Statements.Title"]</h2>
                <p class="action-description">@L["Action.Statements.Description"]</p>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="action-arrow" aria-hidden="true" focusable="false">
                <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
        </a>
    </section>
</div>