@*
    ClientList.razor
    
    Client management page for financial advisors.
    Demonstrates the "RequireAdvisor" policy - accessible by Advisors and Administrators.
    
    Usage:
    Navigate to /advisor/clients when logged in with Advisor or Administrator role.
*@

@page "/advisor/clients"
@attribute [Authorize(Policy = "RequireAdvisor")]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization

<PageTitle>My Clients - RAJ Financial</PageTitle>

<div class="container-fluid py-4">
    @* Page Header *@
    <div class="row mb-4">
        <div class="col">
            <h1 class="h3 mb-0">Client Portfolio Management</h1>
            <p class="text-muted">View and manage client accounts and portfolios</p>
        </div>
        <div class="col-auto">
            <AuthorizeView Policy="RequireAdvisor">
                <Authorized>
                    <button class="btn btn-primary" @onclick="ShowAddClientModal">
                        <span class="oi oi-plus me-2" aria-hidden="true"></span>
                        Add New Client
                    </button>
                </Authorized>
            </AuthorizeView>
        </div>
    </div>

    @* Search and Filter Bar *@
    <div class="row mb-4">
        <div class="col-md-6 col-lg-4">
            <div class="input-group">
                <span class="input-group-text">
                    <span class="oi oi-magnifying-glass" aria-hidden="true"></span>
                </span>
                <input type="text" 
                       class="form-control" 
                       placeholder="Search clients..." 
                       @bind="SearchQuery"
                       @bind:event="oninput"
                       aria-label="Search clients" />
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <select class="form-select" @bind="StatusFilter" aria-label="Filter by status">
                <option value="">All Statuses</option>
                <option value="active">Active</option>
                <option value="inactive">Inactive</option>
                <option value="pending">Pending Review</option>
            </select>
        </div>
    </div>

    @* Client Cards - Responsive grid (card layout for mobile) *@
    <div class="row">
        @foreach (var client in FilteredClients)
        {
            <div class="col-12 col-md-6 col-xl-4 mb-4">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-start mb-3">
                            <div class="avatar bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3"
                                 style="width: 48px; height: 48px;">
                                @client.Initials
                            </div>
                            <div class="flex-grow-1">
                                <h5 class="mb-0">@client.Name</h5>
                                <small class="text-muted">@client.Email</small>
                            </div>
                            <span class="badge @GetStatusBadgeClass(client.Status)">
                                @client.Status
                            </span>
                        </div>
                        
                        <div class="row g-2 mb-3">
                            <div class="col-6">
                                <small class="text-muted d-block">Portfolio Value</small>
                                <strong>@client.PortfolioValue.ToString("C")</strong>
                            </div>
                            <div class="col-6">
                                <small class="text-muted d-block">YTD Return</small>
                                <strong class="@(client.YtdReturn >= 0 ? "text-success" : "text-danger")">
                                    @(client.YtdReturn >= 0 ? "+" : "")@client.YtdReturn.ToString("P2")
                                </strong>
                            </div>
                        </div>
                        
                        <div class="d-flex gap-2">
                            <a href="/advisor/clients/@client.Id" 
                               class="btn btn-outline-primary btn-sm flex-grow-1">
                                View Details
                            </a>
                            <AuthorizeView Policy="RequireAdvisor">
                                <Authorized>
                                    <button class="btn btn-outline-secondary btn-sm" 
                                            aria-label="Edit @client.Name">
                                        <span class="oi oi-pencil" aria-hidden="true"></span>
                                    </button>
                                </Authorized>
                            </AuthorizeView>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!FilteredClients.Any())
    {
        <div class="alert alert-info" role="alert">
            <span class="oi oi-info me-2" aria-hidden="true"></span>
            No clients found matching your search criteria.
        </div>
    }
</div>

@code {
    /// <summary>
    /// Search query for filtering clients by name or email.
    /// </summary>
    private string SearchQuery { get; set; } = string.Empty;

    /// <summary>
    /// Status filter value.
    /// </summary>
    private string StatusFilter { get; set; } = string.Empty;

    /// <summary>
    /// Sample client data - will be replaced with API call.
    /// </summary>
    private List<ClientViewModel> Clients { get; set; } = new()
    {
        new() { Id = Guid.NewGuid(), Name = "John Smith", Email = "john.smith@example.com", Status = "Active", PortfolioValue = 125000, YtdReturn = 0.0823m },
        new() { Id = Guid.NewGuid(), Name = "Sarah Johnson", Email = "sarah.j@example.com", Status = "Active", PortfolioValue = 450000, YtdReturn = 0.1245m },
        new() { Id = Guid.NewGuid(), Name = "Michael Chen", Email = "m.chen@example.com", Status = "Pending Review", PortfolioValue = 75000, YtdReturn = -0.0312m },
        new() { Id = Guid.NewGuid(), Name = "Emily Davis", Email = "emily.davis@example.com", Status = "Active", PortfolioValue = 285000, YtdReturn = 0.0956m },
        new() { Id = Guid.NewGuid(), Name = "Robert Williams", Email = "r.williams@example.com", Status = "Inactive", PortfolioValue = 50000, YtdReturn = 0.0145m }
    };

    /// <summary>
    /// Gets clients filtered by search query and status.
    /// </summary>
    private IEnumerable<ClientViewModel> FilteredClients => Clients
        .Where(c => string.IsNullOrEmpty(SearchQuery) || 
                    c.Name.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) ||
                    c.Email.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase))
        .Where(c => string.IsNullOrEmpty(StatusFilter) || 
                    c.Status.Equals(StatusFilter, StringComparison.OrdinalIgnoreCase));

    /// <summary>
    /// Gets the appropriate CSS class for the status badge.
    /// </summary>
    /// <param name="status">The client status.</param>
    /// <returns>CSS class string for the badge.</returns>
    private static string GetStatusBadgeClass(string status) => status.ToLower() switch
    {
        "active" => "bg-success",
        "inactive" => "bg-secondary",
        "pending review" => "bg-warning text-dark",
        _ => "bg-info"
    };

    /// <summary>
    /// Shows the add client modal dialog.
    /// </summary>
    private void ShowAddClientModal()
    {
        // TODO: Implement modal for adding new client
    }

    /// <summary>
    /// View model for client display.
    /// </summary>
    private class ClientViewModel
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
        public decimal PortfolioValue { get; set; }
        public decimal YtdReturn { get; set; }
        public string Initials => string.Concat(Name.Split(' ').Take(2).Select(n => n[0]));
    }
}

