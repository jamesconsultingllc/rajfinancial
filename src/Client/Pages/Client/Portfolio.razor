@*
    Portfolio.razor
    
    Client portfolio overview page demonstrating the "RequireClient" policy.
    Accessible by Clients, Advisors, and Administrators.
    
    Features:
    - Portfolio summary cards
    - Holdings table with responsive mobile view
    - Recent transactions
    - Responsive design (mobile-first)
    - WCAG 2.1 AA accessible
    - Fully localized
*@

@page "/portfolio"
@attribute [Authorize(Policy = "RequireClient")]
@inject IStringLocalizer<Portfolio> L

<PageTitle>@L["PageTitle"]</PageTitle>

<div class="container-fluid py-4">
    @* Page Header *@
    <div class="row mb-4">
        <div class="col">
            <h1 class="h3 mb-0">@L["Heading"]</h1>
            <p class="text-muted">@L["Subtitle"]</p>
        </div>
    </div>

    @* Portfolio Summary Cards - Mobile-first responsive grid *@
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-4" role="region" aria-label="@L["Heading"]">
        <div class="card bg-primary text-white">
            <div class="card-body">
                <h2 class="h6 text-white-50 mb-1">@L["TotalPortfolioValue"]</h2>
                <p class="h2 mb-0">@TotalValue.ToString("C")</p>
                <small class="@(DailyChange >= 0 ? "text-success-light" : "text-danger-light")">
                    @(DailyChange >= 0 ? "▲" : "▼") @Math.Abs(DailyChange).ToString("C") (@DailyChangePercent.ToString("P2")) @L["Today"]
                </small>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <h2 class="h6 text-muted mb-1">@L["TotalGainLoss"]</h2>
                <p class="h2 @(TotalGain >= 0 ? "text-success" : "text-danger") mb-0">
                    @(TotalGain >= 0 ? "+" : "")@TotalGain.ToString("C")
                </p>
                <small class="text-muted">@TotalGainPercent.ToString("P2") @L["AllTime"]</small>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <h2 class="h6 text-muted mb-1">@L["AvailableCash"]</h2>
                <p class="h2 mb-0">@AvailableCash.ToString("C")</p>
                <small class="text-muted">@L["ReadyToInvest"]</small>
            </div>
        </div>
    </div>

    @* Holdings Table - Desktop table / Mobile cards *@
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h2 class="h5 mb-0">@L["Holdings"]</h2>
            <AuthorizeView Policy="RequireClient">
                <Authorized>
                    <button class="btn btn-sm btn-outline-primary" @onclick="ShowTradeModal">
                        <span class="oi oi-plus me-1" aria-hidden="true"></span>
                        @L["NewTrade"]
                    </button>
                </Authorized>
            </AuthorizeView>
        </div>
        <div class="card-body p-0">
            @* Desktop Table View *@
            <div class="d-none d-md-block table-responsive">
                <table class="table table-hover mb-0" aria-describedby="holdings-caption">
                    <caption id="holdings-caption" class="visually-hidden">@L["Holdings.TableCaption"]</caption>
                    <thead class="table-light">
                    <tr>
                        <th scope="col">@L["Table.Symbol"]</th>
                        <th scope="col">@L["Table.Name"]</th>
                        <th scope="col" class="text-end">@L["Table.Shares"]</th>
                        <th scope="col" class="text-end">@L["Table.Price"]</th>
                        <th scope="col" class="text-end">@L["Table.Value"]</th>
                        <th scope="col" class="text-end">@L["Table.GainLoss"]</th>
                        <th scope="col" class="text-end">@L["Table.Actions"]</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var holding in Holdings)
                    {
                        <tr>
                            <td>
                                <strong>@holding.Symbol</strong>
                            </td>
                            <td>@holding.Name</td>
                            <td class="text-end">@holding.Shares.ToString("N2")</td>
                            <td class="text-end">@holding.CurrentPrice.ToString("C")</td>
                            <td class="text-end">@holding.Value.ToString("C")</td>
                            <td class="text-end @(holding.GainLoss >= 0 ? "text-success" : "text-danger")">
                                @(holding.GainLoss >= 0 ? "+" : "")@holding.GainLoss.ToString("C")
                                <br/>
                                <small>(@holding.GainLossPercent.ToString("P2"))</small>
                            </td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-primary me-1"
                                        aria-label="@string.Format(L["BuyMore.AriaLabel"], holding.Symbol)">
                                    @L["Buy"]
                                </button>
                                <button class="btn btn-sm btn-outline-secondary"
                                        aria-label="@string.Format(L["Sell.AriaLabel"], holding.Symbol)">
                                    @L["Sell"]
                                </button>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>

            @* Mobile Card View *@
            <div class="d-md-none" role="list" aria-label="@L["Holdings"]">
                @foreach (var holding in Holdings)
                {
                    <div class="border-bottom p-3" role="listitem">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                                <strong class="d-block">@holding.Symbol</strong>
                                <small class="text-muted">@holding.Name</small>
                            </div>
                            <div class="text-end">
                                <strong class="d-block">@holding.Value.ToString("C")</strong>
                                <small class="@(holding.GainLoss >= 0 ? "text-success" : "text-danger")">
                                    @(holding.GainLoss >= 0 ? "+" : "")@holding.GainLossPercent.ToString("P2")
                                </small>
                            </div>
                        </div>
                        <div class="d-flex justify-content-between text-muted small mb-2">
                            <span>@string.Format(L["SharesCount"], holding.Shares.ToString("N2"))</span>
                            <span>@string.Format(L["PricePerShare"], holding.CurrentPrice.ToString("C"))</span>
                        </div>
                        <div class="d-flex gap-2">
                            <button class="btn btn-sm btn-outline-primary flex-grow-1"
                                    aria-label="@string.Format(L["BuyMore.AriaLabel"], holding.Symbol)">
                                @L["Buy"]
                            </button>
                            <button class="btn btn-sm btn-outline-secondary flex-grow-1"
                                    aria-label="@string.Format(L["Sell.AriaLabel"], holding.Symbol)">
                                @L["Sell"]
                            </button>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    @* Recent Transactions *@
    <div class="card">
        <div class="card-header">
            <h2 class="h5 mb-0">@L["RecentTransactions"]</h2>
        </div>
        <div class="card-body">
            <ul class="list-unstyled mb-0" role="list">
                @foreach (var transaction in RecentTransactions)
                {
                    <li class="d-flex align-items-center py-2 border-bottom" role="listitem">
                        <span class="badge @(transaction.Type == "Buy" ? "bg-success" : "bg-danger") me-3">
                            @transaction.Type
                        </span>
                        <div class="flex-grow-1">
                            <strong>@transaction.Symbol</strong>
                            <span class="text-muted">- @string.Format(L["Transaction.SharesAt"], transaction.Shares, transaction.Price.ToString("C"))</span>
                        </div>
                        <small class="text-muted">@transaction.Date.ToString("MMM dd, yyyy")</small>
                    </li>
                }
            </ul>
        </div>
    </div>
</div>

@code {

    /// <summary>
    ///     Total portfolio value.
    /// </summary>
    private decimal TotalValue { get; } = 125_432.87m;

    /// <summary>
    ///     Daily change in portfolio value.
    /// </summary>
    private decimal DailyChange { get; } = 1_234.56m;

    /// <summary>
    ///     Daily change percentage.
    /// </summary>
    private decimal DailyChangePercent { get; } = 0.0099m;

    /// <summary>
    ///     Total gain/loss since inception.
    /// </summary>
    private decimal TotalGain { get; } = 25_432.87m;

    /// <summary>
    ///     Total gain/loss percentage.
    /// </summary>
    private decimal TotalGainPercent { get; } = 0.2543m;

    /// <summary>
    ///     Available cash balance.
    /// </summary>
    private decimal AvailableCash { get; } = 5_678.90m;

    /// <summary>
    ///     Portfolio holdings.
    /// </summary>
    private List<HoldingViewModel> Holdings { get; } =
    [
        new HoldingViewModel { Symbol = "AAPL", Name = "Apple Inc.", Shares = 50, CurrentPrice = 178.50m, CostBasis = 150.00m },
        new HoldingViewModel { Symbol = "MSFT", Name = "Microsoft Corp.", Shares = 30, CurrentPrice = 378.25m, CostBasis = 320.00m },
        new HoldingViewModel { Symbol = "GOOGL", Name = "Alphabet Inc.", Shares = 15, CurrentPrice = 141.80m, CostBasis = 125.00m },
        new HoldingViewModel { Symbol = "AMZN", Name = "Amazon.com Inc.", Shares = 25, CurrentPrice = 178.50m, CostBasis = 165.00m },
        new HoldingViewModel { Symbol = "VOO", Name = "Vanguard S&P 500 ETF", Shares = 100, CurrentPrice = 436.25m, CostBasis = 380.00m }
    ];

    /// <summary>
    ///     Recent transactions.
    /// </summary>
    private List<TransactionViewModel> RecentTransactions { get; } =
    [
        new TransactionViewModel { Type = "Buy", Symbol = "AAPL", Shares = 10, Price = 175.00m, Date = DateTime.Now.AddDays(-2) },
        new TransactionViewModel { Type = "Sell", Symbol = "TSLA", Shares = 5, Price = 245.00m, Date = DateTime.Now.AddDays(-5) },
        new TransactionViewModel { Type = "Buy", Symbol = "VOO", Shares = 20, Price = 432.50m, Date = DateTime.Now.AddDays(-10) }
    ];

    /// <summary>
    ///     Shows the trade modal dialog.
    /// </summary>
    private void ShowTradeModal()
    {
        // TODO: Implement trade modal
    }

    /// <summary>
    ///     View model for portfolio holdings.
    /// </summary>
    private class HoldingViewModel
    {
        public string Symbol { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public decimal Shares { get; set; }
        public decimal CurrentPrice { get; set; }
        public decimal CostBasis { get; set; }
        public decimal Value => Shares * CurrentPrice;
        public decimal GainLoss => Shares * (CurrentPrice - CostBasis);
        public decimal GainLossPercent => CostBasis > 0 ? (CurrentPrice - CostBasis) / CostBasis : 0;
    }

    /// <summary>
    ///     View model for transactions.
    /// </summary>
    private class TransactionViewModel
    {
        public string Type { get; set; } = string.Empty;
        public string Symbol { get; set; } = string.Empty;
        public decimal Shares { get; set; }
        public decimal Price { get; set; }
        public DateTime Date { get; set; }
    }

}