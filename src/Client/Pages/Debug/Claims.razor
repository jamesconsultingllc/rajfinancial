@*
    Claims.razor
    
    Debug page to display all claims from the authenticated user's token.
    Use this to verify that roles are being received correctly from Microsoft Entra ID.
    
    Usage:
    Navigate to /debug/claims when logged in to see all token claims.
    
    NOTE: This page should be removed or disabled in production.
*@

@page "/debug/claims"
@attribute [Authorize]
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Debug: User Claims</PageTitle>

<div class="container py-4">
    <div class="card">
        <div class="card-header bg-warning text-dark">
            <h1 class="h4 mb-0">
                <span class="oi oi-bug me-2" aria-hidden="true"></span>
                Debug: User Claims
            </h1>
        </div>
        <div class="card-body">
            <div class="alert alert-warning" role="alert">
                <strong>?? Debug Page</strong> - This page displays sensitive token information.
                Remove or disable this page before deploying to production.
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger" role="alert">
                    <strong>Error:</strong> @errorMessage
                </div>
            }

            @if (claims == null)
            {
                <div class="d-flex flex-column align-items-center py-4">
                    <div class="text-center">
                        <h2 class="h5 mb-3">No Claims Found</h2>
                        <p class="text-muted mb-4">
                            If you just logged in, it may take a moment for claims to be available.
                            Ensure your account has the necessary roles and claims assigned in Azure.
                        </p>
                    </div>
                </div>
            }
            else
            {
                <section class="mb-4">
                    <h2 class="h5 mb-3">User Identity</h2>
                    <dl class="row">
                        <dt class="col-sm-3">Name</dt>
                        <dd class="col-sm-9">
                            <code>@userName</code>
                        </dd>

                        <dt class="col-sm-3">Is Authenticated</dt>
                        <dd class="col-sm-9">
                            @if (isAuthenticated)
                            {
                                <span class="badge bg-success">Yes</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">No</span>
                            }
                        </dd>

                        <dt class="col-sm-3">Authentication Type</dt>
                        <dd class="col-sm-9">
                            <code>@(authenticationType ?? "N/A")</code>
                        </dd>
                    </dl>
                </section>

                <section class="mb-4">
                    <h2 class="h5 mb-3">
                        Roles
                        <span class="badge bg-secondary">@roles.Count()</span>
                    </h2>
                    @if (roles.Any())
                    {
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var role in roles)
                            {
                                <span class="badge bg-primary fs-6">@role</span>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-danger" role="alert">
                            <strong>No roles found!</strong> This is likely why authorization policies are failing.
                            <hr/>
                            <p class="mb-0">To fix this:</p>
                            <ol class="mb-0 mt-2">
                                <li>Go to Azure Portal ? App Registrations ? Your App ? App roles</li>
                                <li>Create roles: <code>Administrator</code>, <code>Advisor</code>, <code>Client</code>, <code>Viewer</code></li>
                                <li>Go to Enterprise Applications ? Your App ? Users and groups</li>
                                <li>Assign the test user to the appropriate role</li>
                                <li>Ensure Token Configuration includes the <code>roles</code> claim</li>
                            </ol>
                        </div>
                    }
                </section>

                <section>
                    <h2 class="h5 mb-3">
                        All Claims
                        <span class="badge bg-secondary">@claims.Count()</span>
                    </h2>
                    <div class="table-responsive">
                        <table class="table table-striped table-hover table-sm" aria-describedby="claims-caption">
                            <caption id="claims-caption" class="visually-hidden">User token claims and their values</caption>
                            <thead class="table-dark">
                            <tr>
                                <th scope="col" style="width: 40%">Claim Type</th>
                                <th scope="col" style="width: 60%">Value</th>
                            </tr>
                            </thead>
                            <tbody>
                            @foreach (var claim in claims.OrderBy(c => c.Type))
                            {
                                <tr class="@GetRowClass(claim.Type)">
                                    <td>
                                        <code class="text-break">@GetFriendlyClaimType(claim.Type)</code>
                                        @if (IsRoleClaim(claim.Type))
                                        {
                                            <span class="badge bg-success ms-2">Role</span>
                                        }
                                    </td>
                                    <td>
                                        <code class="text-break">@claim.Value</code>
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </section>

                <section class="mt-4">
                    <h2 class="h5 mb-3">Expected Role Claim Types</h2>
                    <p class="text-muted">Look for these claim types in the table above:</p>
                    <ul>
                        <li><code>roles</code> - Standard Entra ID app roles</li>
                        <li><code>http://schemas.microsoft.com/ws/2008/06/identity/claims/role</code> - .NET role claim</li>
                        <li><code>extension_Role</code> - Custom attribute (Entra External ID)</li>
                    </ul>
                </section>
            }
        </div>
    </div>
</div>

@code {
    private IEnumerable<Claim>? claims;
    private IEnumerable<string> roles = Enumerable.Empty<string>();
    private string? userName;
    private bool isAuthenticated;
    private string? authenticationType;
    private string? errorMessage;

    /// <summary>
    ///     Loads the current user's authentication state and extracts claims.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            isAuthenticated = user.Identity?.IsAuthenticated ?? false;
            userName = user.Identity?.Name;
            authenticationType = user.Identity?.AuthenticationType;
            claims = user.Claims.ToList();

            // Extract roles from various possible claim types
            roles = claims
                .Where(c => IsRoleClaim(c.Type))
                .Select(c => c.Value)
                .Distinct()
                .ToList();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading claims: {ex.Message}";
            claims = new List<Claim>();
            roles = new List<string>();
        }
    }

    /// <summary>
    ///     Determines if a claim type represents a role.
    /// </summary>
    private static bool IsRoleClaim(string claimType)
    {
        return claimType.Equals("roles", StringComparison.OrdinalIgnoreCase) ||
               claimType.Equals("role", StringComparison.OrdinalIgnoreCase) ||
               claimType.EndsWith("/role", StringComparison.OrdinalIgnoreCase) ||
               claimType.Contains("extension_Role", StringComparison.OrdinalIgnoreCase);
    }

    /// <summary>
    ///     Gets a friendly display name for common claim types.
    /// </summary>
    private static string GetFriendlyClaimType(string claimType)
    {
        // Show the full type but highlight common ones
        return claimType switch
        {
            "http://schemas.xmlsoap.org/ws/2005/05/identity/claims/name" => "name (identity)",
            "http://schemas.xmlsoap.org/ws/2005/05/identity/claims/emailaddress" => "email",
            "http://schemas.microsoft.com/ws/2008/06/identity/claims/role" => "role (.NET)",
            "http://schemas.microsoft.com/identity/claims/objectidentifier" => "oid (Object ID)",
            "http://schemas.microsoft.com/identity/claims/tenantid" => "tid (Tenant ID)",
            _ => claimType
        };
    }

    /// <summary>
    ///     Gets a CSS class for highlighting important rows.
    /// </summary>
    private static string GetRowClass(string claimType)
    {
        if (IsRoleClaim(claimType))
            return "table-success";

        if (claimType.Contains("name", StringComparison.OrdinalIgnoreCase) ||
            claimType.Contains("email", StringComparison.OrdinalIgnoreCase))
            return "table-info";

        return string.Empty;
    }

}