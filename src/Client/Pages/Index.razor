@*
    Index.razor
    
    Landing page / Home page for RAJ Financial.
    - Authenticated users are redirected to their appropriate dashboard
    - Unauthenticated visitors see the marketing landing page
    
    Features:
    - Hero section with brand messaging
    - Detailed feature showcase
    - How it works section
    - Security & trust indicators
    - Call-to-action sections
    - Responsive design (mobile-first)
    - WCAG 2.1 AA accessible
    - Fully localized
*@

@page "/"

@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<Index> L
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>@L["PageTitle"]</PageTitle>

@if (_isLoading)
{
    <div class="d-flex justify-content-center align-items-center" style="min-height: 50vh;">
        <div class="text-center">
            <div class="spinner-border text-primary mb-3" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="text-muted">Loading...</p>
        </div>
    </div>
}
else if (!_isAuthenticated)
{
    <div class="home-container">
        @* ════════════════════════════════════════════════════════════════════════
           PUBLIC LANDING PAGE
           ════════════════════════════════════════════════════════════════════════ *@
        
        @* Hero Section *@
        <section class="hero-section" aria-labelledby="hero-heading">
            <div class="hero-background" aria-hidden="true">
                <div class="hero-gradient"></div>
                <div class="hero-pattern"></div>
            </div>
            
            <div class="hero-content animate-fade-in">
                <img src="/images/brand/logo-icon.svg" alt="" class="hero-logo" width="64" height="64" role="presentation" />
                
                <h1 id="hero-heading" class="hero-title">
                    @L["Hero.Title.Line1"]
                    <span class="hero-title-accent">@L["Hero.Title.Line2"]</span>
                </h1>
                
                <p class="hero-description">
                    @L["Hero.Description"]
                </p>
                
                <div class="hero-actions">
                    <a href="authentication/register" class="btn btn-gold-solid btn-lg">
                        @L["Hero.CTA.GetStarted"]
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                            <polyline points="12 5 19 12 12 19"></polyline>
                        </svg>
                    </a>
                    <a href="#features" class="btn btn-gold-outline-dark btn-lg">
                        @L["Hero.CTA.ExploreFeatures"]
                    </a>
                </div>
                
                <div class="hero-trust-badges animate-slide-up" style="animation-delay: 200ms;">
                    <div class="trust-badge">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                        </svg>
                        <span>@L["Trust.Badge.Security"]</span>
                    </div>
                    <div class="trust-badge">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                            <polyline points="22 4 12 14.01 9 11.01"></polyline>
                        </svg>
                        <span>@L["Trust.Badge.Free"]</span>
                    </div>
                    <div class="trust-badge">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                            <circle cx="12" cy="12" r="10"></circle>
                            <polyline points="12 6 12 12 16 14"></polyline>
                        </svg>
                        <span>@L["Trust.Badge.Setup"]</span>
                    </div>
                </div>
            </div>
        </section>

        @* Core Features Section *@
        <section id="features" class="features-section" aria-labelledby="features-heading">
            <div class="section-header">
                <span class="section-label">@L["Features.Label"]</span>
                <h2 id="features-heading" class="section-title">@L["Features.Title"]</h2>
                <p class="section-subtitle">
                    @L["Features.Subtitle"]
                </p>
            </div>
            
            <div class="features-grid" role="list">
                <article class="feature-card card-glass animate-slide-up stagger-1" role="listitem">
                    <div class="feature-icon gradient-gold" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                            <path d="M21.21 15.89A10 10 0 1 1 8 2.83"></path>
                            <path d="M22 12A10 10 0 0 0 12 2v10z"></path>
                        </svg>
                    </div>
                    <h3 class="feature-title">@L["Feature.NetWorth.Title"]</h3>
                    <p class="feature-description">
                        @L["Feature.NetWorth.Description"]
                    </p>
                    <ul class="feature-list" aria-label="Features">
                        <li>@L["Feature.NetWorth.Item1"]</li>
                        <li>@L["Feature.NetWorth.Item2"]</li>
                        <li>@L["Feature.NetWorth.Item3"]</li>
                    </ul>
                </article>

                <article class="feature-card card-glass animate-slide-up stagger-2" role="listitem">
                    <div class="feature-icon gradient-gold" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                            <rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect>
                            <line x1="1" y1="10" x2="23" y2="10"></line>
                        </svg>
                    </div>
                    <h3 class="feature-title">@L["Feature.BankLinking.Title"]</h3>
                    <p class="feature-description">
                        @L["Feature.BankLinking.Description"]
                    </p>
                    <ul class="feature-list" aria-label="Features">
                        <li>@L["Feature.BankLinking.Item1"]</li>
                        <li>@L["Feature.BankLinking.Item2"]</li>
                        <li>@L["Feature.BankLinking.Item3"]</li>
                    </ul>
                </article>

                <article class="feature-card card-glass animate-slide-up stagger-3" role="listitem">
                    <div class="feature-icon gradient-gold" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                            <path d="M3 3v18h18"></path>
                            <path d="M18.7 8l-5.1 5.2-2.8-2.7L7 14.3"></path>
                        </svg>
                    </div>
                    <h3 class="feature-title">@L["Feature.Analytics.Title"]</h3>
                    <p class="feature-description">
                        @L["Feature.Analytics.Description"]
                    </p>
                    <ul class="feature-list" aria-label="Features">
                        <li>@L["Feature.Analytics.Item1"]</li>
                        <li>@L["Feature.Analytics.Item2"]</li>
                        <li>@L["Feature.Analytics.Item3"]</li>
                    </ul>
                </article>

                <article class="feature-card card-glass animate-slide-up stagger-1" role="listitem">
                    <div class="feature-icon gradient-gold" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                            <line x1="12" y1="1" x2="12" y2="23"></line>
                            <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                        </svg>
                    </div>
                    <h3 class="feature-title">@L["Feature.DebtPayoff.Title"]</h3>
                    <p class="feature-description">
                        @L["Feature.DebtPayoff.Description"]
                    </p>
                    <ul class="feature-list" aria-label="Features">
                        <li>@L["Feature.DebtPayoff.Item1"]</li>
                        <li>@L["Feature.DebtPayoff.Item2"]</li>
                        <li>@L["Feature.DebtPayoff.Item3"]</li>
                    </ul>
                </article>

                <article class="feature-card card-glass animate-slide-up stagger-2" role="listitem">
                    <div class="feature-icon gradient-gold" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                        </svg>
                    </div>
                    <h3 class="feature-title">@L["Feature.Insurance.Title"]</h3>
                    <p class="feature-description">
                        @L["Feature.Insurance.Description"]
                    </p>
                    <ul class="feature-list" aria-label="Features">
                        <li>@L["Feature.Insurance.Item1"]</li>
                        <li>@L["Feature.Insurance.Item2"]</li>
                        <li>@L["Feature.Insurance.Item3"]</li>
                    </ul>
                </article>

                <article class="feature-card card-glass animate-slide-up stagger-3" role="listitem">
                    <div class="feature-icon gradient-gold" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                            <circle cx="9" cy="7" r="4"></circle>
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                        </svg>
                    </div>
                    <h3 class="feature-title">@L["Feature.Beneficiaries.Title"]</h3>
                    <p class="feature-description">
                        @L["Feature.Beneficiaries.Description"]
                    </p>
                    <ul class="feature-list" aria-label="Features">
                        <li>@L["Feature.Beneficiaries.Item1"]</li>
                        <li>@L["Feature.Beneficiaries.Item2"]</li>
                        <li>@L["Feature.Beneficiaries.Item3"]</li>
                    </ul>
                </article>
            </div>
        </section>

        @* How It Works Section *@
        <section class="how-it-works-section" aria-labelledby="how-it-works-heading">
            <div class="section-header">
                <span class="section-label">@L["HowItWorks.Label"]</span>
                <h2 id="how-it-works-heading" class="section-title">@L["HowItWorks.Title"]</h2>
                <p class="section-subtitle">
                    @L["HowItWorks.Subtitle"]
                </p>
            </div>
            
            <ol class="steps-grid">
                <li class="step-card animate-slide-up stagger-1">
                    <div class="step-number" aria-hidden="true">1</div>
                    <h3 class="step-title">@L["Step.1.Title"]</h3>
                    <p class="step-description">
                        @L["Step.1.Description"]
                    </p>
                </li>
                
                <li class="step-card animate-slide-up stagger-2">
                    <div class="step-number" aria-hidden="true">2</div>
                    <h3 class="step-title">@L["Step.2.Title"]</h3>
                    <p class="step-description">
                        @L["Step.2.Description"]
                    </p>
                </li>
                
                <li class="step-card animate-slide-up stagger-3">
                    <div class="step-number" aria-hidden="true">3</div>
                    <h3 class="step-title">@L["Step.3.Title"]</h3>
                    <p class="step-description">
                        @L["Step.3.Description"]
                    </p>
                </li>
            </ol>
        </section>

        @* Security & Trust Section *@
        <section class="trust-section" aria-labelledby="security-heading">
            <div class="section-header">
                <span class="section-label">@L["Security.Label"]</span>
                <h2 id="security-heading" class="section-title">@L["Security.Title"]</h2>
                <p class="section-subtitle">
                    @L["Security.Subtitle"]
                </p>
            </div>
            
            <div class="trust-grid" role="list">
                <article class="trust-card animate-slide-up stagger-1" role="listitem">
                    <div class="trust-icon" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                        </svg>
                    </div>
                    <h3 class="trust-title">@L["Security.Encryption.Title"]</h3>
                    <p class="trust-description">@L["Security.Encryption.Description"]</p>
                </article>
                
                <article class="trust-card animate-slide-up stagger-2" role="listitem">
                    <div class="trust-icon" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                            <path d="M9 12l2 2 4-4"></path>
                        </svg>
                    </div>
                    <h3 class="trust-title">@L["Security.ReadOnly.Title"]</h3>
                    <p class="trust-description">@L["Security.ReadOnly.Description"]</p>
                </article>
                
                <article class="trust-card animate-slide-up stagger-3" role="listitem">
                    <div class="trust-icon" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" y1="8" x2="12" y2="12"></line>
                            <line x1="12" y1="16" x2="12.01" y2="16"></line>
                        </svg>
                    </div>
                    <h3 class="trust-title">@L["Security.NoSelling.Title"]</h3>
                    <p class="trust-description">@L["Security.NoSelling.Description"]</p>
                </article>
                
                <article class="trust-card animate-slide-up stagger-4" role="listitem">
                    <div class="trust-icon" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                            <polyline points="3 6 5 6 21 6"></polyline>
                            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                        </svg>
                    </div>
                    <h3 class="trust-title">@L["Security.Delete.Title"]</h3>
                    <p class="trust-description">@L["Security.Delete.Description"]</p>
                </article>
            </div>
        </section>

        @* Final CTA Section *@
        <section class="cta-section" aria-labelledby="cta-heading">
            <div class="cta-content animate-scale-in">
                <h2 id="cta-heading" class="cta-title">@L["CTA.Title"]</h2>
                <p class="cta-description">
                    @L["CTA.Description"]
                </p>
                <div class="cta-actions">
                    <a href="authentication/register" class="btn btn-gold-solid btn-lg">
                        @L["CTA.Button"]
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                            <polyline points="12 5 19 12 12 19"></polyline>
                        </svg>
                    </a>
                </div>
            </div>
        </section>

        @* Footer *@
        <footer class="landing-footer">
            <div class="footer-content">
                <div class="footer-brand">
                    <img src="/images/brand/logo-icon.svg" alt="" width="32" height="32" role="presentation" />
                    <span class="footer-brand-text">RAJ Financial</span>
                </div>
                <p class="footer-copyright">@string.Format(L["Footer.Copyright"], DateTime.Now.Year)</p>
            </div>
        </footer>
    </div>
}

@code {
    private bool _isLoading = true;
    private bool _isAuthenticated;

    /// <summary>
    /// Checks authentication state and redirects authenticated users to their dashboard.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        
        _isAuthenticated = user.Identity?.IsAuthenticated is true;
        
        if (_isAuthenticated)
        {
            // Redirect based on role - Administrators go to admin dashboard, others to client dashboard
            if (user.IsInRole("Administrator") || user.IsInRole("AdminAdvisor") || user.IsInRole("AdminClient"))
            {
                Navigation.NavigateTo("/admin/dashboard", forceLoad: false);
            }
            else if (user.IsInRole("Advisor"))
            {
                Navigation.NavigateTo("/advisor/clients", forceLoad: false);
            }
            else
            {
                // Default for Client, Viewer, or any authenticated user
                Navigation.NavigateTo("/dashboard", forceLoad: false);
            }
        }
        
        _isLoading = false;
    }
}

