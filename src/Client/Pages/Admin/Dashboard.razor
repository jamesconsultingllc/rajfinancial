@*
    Dashboard.razor
    
    Administrative dashboard demonstrating policy-based authorization.
    This page requires the "RequireAdministrator" policy.
    
    Features:
    - System statistics overview
    - Quick action links
    - Recent activity feed
    - Responsive design (mobile-first)
    - WCAG 2.1 AA accessible
    - Fully localized
*@

@page "/admin/dashboard"
@attribute [Authorize(Policy = "RequireAdministrator")]

@using Microsoft.Extensions.Localization
@inject IStringLocalizer<Dashboard> L

<PageTitle>@L["PageTitle"]</PageTitle>

<div class="container-fluid py-4" data-testid="admin-dashboard">
    @* Page Header *@
    <div class="row mb-4">
        <div class="col">
            <h1 class="h3 mb-0" data-testid="admin-dashboard-title">@L["Heading"]</h1>
            <p class="text-muted">@L["Subtitle"]</p>
        </div>
    </div>

    @* Stats Cards Row - Responsive grid *@
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-4" role="region" aria-label="@L["Heading"]">
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <span class="oi oi-people fs-2 text-primary" aria-hidden="true"></span>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h2 class="h6 text-muted mb-0">@L["Stats.TotalUsers"]</h2>
                        <p class="h3 mb-0">@TotalUsers</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <span class="oi oi-briefcase fs-2 text-success" aria-hidden="true"></span>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h2 class="h6 text-muted mb-0">@L["Stats.ActiveAdvisors"]</h2>
                        <p class="h3 mb-0">@ActiveAdvisors</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <span class="oi oi-wallet fs-2 text-warning" aria-hidden="true"></span>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h2 class="h6 text-muted mb-0">@L["Stats.TotalClients"]</h2>
                        <p class="h3 mb-0">@TotalClients</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <span class="oi oi-dollar fs-2 text-info" aria-hidden="true"></span>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h2 class="h6 text-muted mb-0">@L["Stats.AssetsUnderMgmt"]</h2>
                        <p class="h3 mb-0">@AssetsUnderManagement.ToString("C0")</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* Admin Quick Actions - Using AuthorizeView for granular control *@
    <div class="row">
        <div class="col-lg-8 mb-4">
            <div class="card h-100">
                <div class="card-header">
                    <h2 class="h5 mb-0" data-testid="quick-actions">@L["QuickActions"]</h2>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        @* User Management - Admin only *@
                        <AuthorizeView Policy="RequireAdministrator">
                            <Authorized>
                                <div class="col-md-6">
                                    <a href="/admin/users" class="btn btn-outline-primary w-100 py-3" data-testid="qa-manage-users">
                                        <span class="oi oi-people me-2" aria-hidden="true"></span>
                                        @L["Action.ManageUsers"]
                                    </a>
                                </div>
                                <div class="col-md-6">
                                    <a href="/admin/settings" class="btn btn-outline-secondary w-100 py-3" data-testid="qa-system-settings">
                                        <span class="oi oi-cog me-2" aria-hidden="true"></span>
                                        @L["Action.SystemSettings"]
                                    </a>
                                </div>
                                <div class="col-md-6">
                                    <a href="/admin/audit-logs" class="btn btn-outline-info w-100 py-3" data-testid="qa-audit-logs">
                                        <span class="oi oi-list me-2" aria-hidden="true"></span>
                                        @L["Action.AuditLogs"]
                                    </a>
                                </div>
                                <div class="col-md-6">
                                    <a href="/admin/reports" class="btn btn-outline-success w-100 py-3" data-testid="qa-system-reports">
                                        <span class="oi oi-graph me-2" aria-hidden="true"></span>
                                        @L["Action.SystemReports"]
                                    </a>
                                </div>
                            </Authorized>
                        </AuthorizeView>
                    </div>
                </div>
            </div>
        </div>

        @* Recent Activity *@
        <div class="col-lg-4 mb-4">
            <div class="card h-100">
                <div class="card-header">
                    <h2 class="h5 mb-0" data-testid="recent-activity">@L["RecentActivity"]</h2>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled mb-0" role="list">
                        <li class="d-flex align-items-center mb-3">
                            <span class="badge bg-success me-2">@L["Activity.New"]</span>
                            <span class="text-muted small">@L["Activity.UserRegistration"]</span>
                        </li>
                        <li class="d-flex align-items-center mb-3">
                            <span class="badge bg-info me-2">@L["Activity.Info"]</span>
                            <span class="text-muted small">@L["Activity.SystemBackup"]</span>
                        </li>
                        <li class="d-flex align-items-center mb-3">
                            <span class="badge bg-warning me-2">@L["Activity.Alert"]</span>
                            <span class="text-muted small">@L["Activity.TransactionFlagged"]</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    /// <summary>
    /// Total number of registered users in the system.
    /// </summary>
    private int TotalUsers { get; set; } = 156;

    /// <summary>
    /// Number of advisors currently active.
    /// </summary>
    private int ActiveAdvisors { get; set; } = 12;

    /// <summary>
    /// Total number of client accounts.
    /// </summary>
    private int TotalClients { get; set; } = 142;

    /// <summary>
    /// Total assets under management in USD.
    /// </summary>
    private decimal AssetsUnderManagement { get; set; } = 45_750_000;

    // TODO: Implement data fetching from API
    // protected override async Task OnInitializedAsync()
    // {
    //     await LoadDashboardData();
    // }
}

