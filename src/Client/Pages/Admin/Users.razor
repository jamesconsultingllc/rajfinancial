@*
    Users.razor
    
    User management page for administrators.
    
    Features:
    - List of active users with roles and status
    - Responsive design (mobile-first)
    - WCAG 2.1 AA accessible
    - Fully localized
*@

@page "/admin/users"
@attribute [Authorize(Policy = "RequireAdministrator")]
@inject IStringLocalizer<Users> L

<PageTitle>@L["PageTitle"]</PageTitle>

<div class="container-fluid py-4" data-testid="admin-users">
    <div class="row mb-4">
        <div class="col">
            <h1 class="h3 mb-0" data-testid="admin-users-title">@L["Heading"]</h1>
            <p class="text-muted">@L["Subtitle"]</p>
        </div>
        <div class="col-auto">
            <button class="btn btn-primary" data-testid="add-user">
                <span class="oi oi-plus me-2" aria-hidden="true"></span>
                @L["AddUser"]
            </button>
        </div>
    </div>

    <AuthorizeView Policy="RequireAdministrator">
        <Authorized>
            <div class="card" data-testid="active-users">
                <div class="card-header">
                    <h2 class="h5 mb-0">@L["ActiveUsers"]</h2>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover" data-testid="user-table" aria-describedby="user-table-caption">
                            <caption id="user-table-caption" class="visually-hidden">@L["Table.Caption"]</caption>
                            <thead>
                            <tr>
                                <th scope="col">@L["Table.Name"]</th>
                                <th scope="col">@L["Table.Email"]</th>
                                <th scope="col">@L["Table.Role"]</th>
                                <th scope="col">@L["Table.Status"]</th>
                                <th scope="col">@L["Table.Actions"]</th>
                            </tr>
                            </thead>
                            <tbody>
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">
                                    @L["NoUsersFound"]
                                </td>
                            </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </Authorized>
        <NotAuthorized>
            <div class="alert alert-danger" role="alert">
                <h4 class="alert-heading">@L["AccessDenied"]</h4>
                <p>@L["AccessDenied.Message"]</p>
            </div>
        </NotAuthorized>
    </AuthorizeView>
</div>

