# Development environment
# For local development with real auth, create .env.local to override these
# Example: Copy this file to .env.local and replace with your tenant values
VITE_AZURE_AD_AUTHORITY=https://{your-tenant}.ciamlogin.com/{your-tenant}.onmicrosoft.com
VITE_AZURE_AD_CLIENT_ID=YOUR_AZURE_AD_CLIENT_ID
VITE_MSAL_CACHE_LOCATION=sessionStorage
