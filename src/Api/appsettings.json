{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "RajFinancial": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Ai": {
    "DefaultProvider": "Anthropic",
    "Providers": {
      "Anthropic": {
        "Model": "claude-sonnet-4-5",
        "ApiKeyEnvVar": "ANTHROPIC_API_KEY"
      }
    }
  },
  "EntraExternalId": {
    "Instance": "https://rajfinancialprod.ciamlogin.com/",
    "CallbackPath": "/signin-oidc",
    "SignedOutCallbackPath": "/signout-callback-oidc"
  },
  "AppRoles": {
    "Client": "<SET-IN-ENVIRONMENT>",
    "Administrator": "<SET-IN-ENVIRONMENT>",
    "Advisor": "<SET-IN-ENVIRONMENT>"
  }
}
