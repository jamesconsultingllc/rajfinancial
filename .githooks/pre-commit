#!/usr/bin/env sh
# Pre-commit hook: (1) ESLint TypeScript, (2) JetBrains InspectCode C#.
# Both target staged files only. If a check runs and fails, it blocks the
# commit. The checks are best-effort and may be skipped when PowerShell or a
# required tool (npx + ESLint, jb InspectCode) is unavailable on the machine.
#
# Bypass in emergencies with: git commit --no-verify
#
# One-time setup per machine:
#   git config core.hooksPath .githooks

set -e

# Prefer pwsh (PowerShell 7+), fall back to Windows PowerShell.
if command -v pwsh >/dev/null 2>&1; then
  PS="pwsh"
elif command -v powershell >/dev/null 2>&1; then
  PS="powershell"
else
  echo "pre-commit: neither 'pwsh' nor 'powershell' found on PATH; skipping hooks" >&2
  exit 0
fi

"$PS" -NoProfile -ExecutionPolicy Bypass -File scripts/precommit-lint.ps1
"$PS" -NoProfile -ExecutionPolicy Bypass -File scripts/precommit-inspect.ps1
